# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# --- Redis (rate limiting, task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM providers ---
# Anthropic — chat completions (default model: claude-sonnet-4-6)
ANTHROPIC_API_KEY=
# Voyage AI — embeddings (Claude has no embeddings API)
VOYAGE_API_KEY=
# Optional model overrides
# LLM_CHAT_MODEL=claude-sonnet-4-6
# LLM_EMBEDDING_MODEL=voyage-3.5
# LLM_MAX_OUTPUT_TOKENS=4096

# --- Auth ---
# JWKS endpoint exposed by Better Auth in apps/web, used to validate JWTs
AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks
# Optional: when set, iss/aud claims are verified (recommended in production)
# AUTH_JWT_ISSUER=http://localhost:3000
# AUTH_JWT_AUDIENCE=http://localhost:3000

# --- Email delivery ---
# Without RESEND_API_KEY, emails are NOT sent: they are logged to the API
# console (look for "email.console" in the logs — invitation links included).
# Get a key at https://resend.com — free tier: 3000 emails/month.
# RESEND_API_KEY=
# Sender address. The default onboarding@resend.dev only delivers to the
# email of your own Resend account — verify a domain to send to anyone.
# EMAIL_FROM=invites@yourdomain.com

# --- Web app ---
# Used to build links in emails and as the allowed CORS origin.
WEB_BASE_URL=http://localhost:3000

# --- Environment ---
# local | production — controls logging format, docs exposure, CORS
APP_ENV=local

# --- Tracing (optional) ---
# OTEL_ENABLED=true
# Spans go to this OTLP endpoint when set, to the console otherwise.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=saas-genai-starter-api

# --- Org-provided API keys (BYO-key) ---
# Encrypts organization API keys at rest. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# --- Platform admin ---
# Comma-separated emails allowed on /admin (cross-tenant stats, limit overrides).
# ADMIN_EMAILS=you@yourdomain.com

# --- Background jobs ---
# arq (local/default, needs `make worker`) | cloud_tasks (production push)
# QUEUE_DRIVER=arq
# Required when QUEUE_DRIVER=cloud_tasks:
# CLOUD_TASKS_QUEUE=projects/PROJECT/locations/REGION/queues/jobs
# INTERNAL_JOBS_BASE_URL=https://api-xxxx.run.app
# JOBS_SERVICE_ACCOUNT_EMAIL=jobs-invoker@PROJECT.iam.gserviceaccount.com
